# Banco (Supabase como banco unico do projeto)
# - DATABASE_URL: conexao usada pela API (runtime web). Deve usar o transaction pooler :6543
#   com role dedicada sem BYPASSRLS (o boot falha se o host for Supabase e a URL for :5432 ou role postgres*).
# - DIRECT_URL: conexao direta para migrations/seed (porta 5432), tipicamente mesma instancia que o worker.
# - WORKER_DATABASE_URL: opcional; sobrescreve DIRECT_URL para o worker dedicado (recomendado em producao).
# Crie roles npbb_api / npbb_worker com o SQL em scripts/sql/create_npbb_runtime_roles.sql (senhas fora do git).
#
# Exemplo Supabase (substitua host, usuario e senha reais — NAO use a role postgres na DATABASE_URL da API):
# DATABASE_URL="postgresql+psycopg2://npbb_api:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql+psycopg2://postgres.<project_ref>:<password>@db.<project_ref>.supabase.co:5432/postgres"
# WORKER_DATABASE_URL="postgresql+psycopg2://npbb_worker:<password>@db.<project_ref>.supabase.co:5432/postgres"
#
# Alternativa: PostgreSQL local (dev):
# DATABASE_URL="postgresql+psycopg2://seu_usuario_sistema@127.0.0.1:5432/npbb"
# DIRECT_URL="postgresql+psycopg2://seu_usuario_sistema@127.0.0.1:5432/npbb"
#
# Migracao F2 (backup Supabase + export local): scripts/backup_export_migracao.py
# SUPABASE_DIRECT_URL - conexao direct ao Supabase (porta 5432) para backup
# LOCAL_DIRECT_URL - conexao ao PostgreSQL local para export (ex.: postgresql+psycopg2://user@127.0.0.1:5432/npbb)
# Migracao F2 (recarga Supabase): scripts/recarga_migracao.py
# - SUPABASE_DIRECT_URL ou DIRECT_URL: manutencao (limpeza/import)
# - DATABASE_URL: runtime; a consolidacao so libera F2-02-002 quando alinhada ao mesmo Supabase alvo da recarga (conectividade remota isolada nao basta)
# Migracao F2 (validacao pos-carga): scripts/validacao_pos_carga_migracao.py
# - requer backup_supabase_*.dump e export_local_*.dump em artifacts_migracao/
# - valida pg_restore, alinhamento entre DATABASE_URL e DIRECT_URL/SUPABASE_DIRECT_URL
# - bloqueia liberacao para F3 quando backup/export estiverem ilegiveis ou o alvo divergir

DATABASE_URL=
DIRECT_URL=
WORKER_DATABASE_URL=
# SUPABASE_DIRECT_URL=
# LOCAL_DIRECT_URL=

# Guard rail: falha o boot da API se DATABASE_URL do Supabase nao estiver no pooler :6543
# ou se a role for postgres. Desative so em debugging controlado.
DB_REQUIRE_SUPABASE_POOLER=true

# Execucao inline de jobs ETL na propria API (apenas dev/teste). Em producao use o worker e deixe false/vazio.
# TESTING=true tambem habilita execucao inline nos testes automatizados.
LEAD_IMPORT_JOB_INLINE_EXECUTION=false

# Log NDJSON de depuracao do agente (gravacao em disco). Padrao: desligado.
NPBB_DEBUG_AGENT_LOG=false

# Se a API der timeout ao Supabase na porta 6543 (firewall/rede corporativa), tente DATABASE_URL
# com :5432 no mesmo host do pooler (session mode) ou use Postgres local (linhas 10-12).
DB_CONNECT_TIMEOUT=5
DB_POOL_TIMEOUT=5
DB_STATEMENT_TIMEOUT_MS=15000
# Pipeline Gold: timeout por statement/transacao de cada chunk de persistencia no banco,
# nao da execucao inteira do pipeline.
LEAD_GOLD_STATEMENT_TIMEOUT_MS=600000
# Heartbeat de progresso entre commits para evitar falso alerta de stall na UI quando
# a persistencia de um chunk esta lenta, mas ainda saudavel.
LEAD_GOLD_PROGRESS_HEARTBEAT_SECONDS=20
# Quando DATABASE_URL aponta para o pooler transacional compartilhado do Supabase (:6543),
# o Gold reduz o chunk efetivo e limita o tempo maximo da transacao aberta.
LEAD_GOLD_INSERT_COMMIT_BATCH_SIZE_SUPABASE_POOLER_6543=25
LEAD_GOLD_INSERT_MAX_TRANSACTION_SECONDS_SUPABASE_POOLER_6543=15

# Worker dedicado de ingestao/ETL/Gold.
LEADS_WORKER_IDLE_SLEEP_SECONDS=2
LEADS_WORKER_FAILURE_SLEEP_SECONDS=5
LEADS_WORKER_HEALTH_FILE=backend/.runtime/leads_worker_health.json
LEADS_WORKER_LOG_LEVEL=INFO

# Payloads de importacao: nao grave blob pesado no banco em producao.
# - local: filesystem local (dev)
# - supabase: Supabase Storage via API HTTP
# Em producao, OBJECT_STORAGE_BACKEND=local falha explicitamente para evitar storage efemero silencioso.
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_BUCKET=lead-imports
OBJECT_STORAGE_LOCAL_ROOT=backend/.local-storage
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_SERVICE_ROLE_KEY=
# Criar bucket uma vez: python scripts/create_supabase_storage_bucket.py

# Logs SQL (opcional)
SQL_ECHO=false

# Auth / JWT
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS (pode ser lista separada por virgula)
# Dica (dev): se FRONTEND_ORIGIN incluir localhost/127.0.0.1, a API libera automaticamente qualquer porta local.
FRONTEND_ORIGIN=http://localhost:5173
# (Opcional) regex para liberar origens adicionais (tem precedencia sobre a regra automatica acima)
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# URL publica do frontend (para gerar links exibidos na API, ex.: landing/promotor)
# Se vazio, usa o primeiro origin de FRONTEND_ORIGIN.
PUBLIC_APP_BASE_URL=

# URL publica do backend para check-in sem QR/questionario (se vazio, usa request.base_url).
PUBLIC_LANDING_BASE_URL=

# (Opcional) URL publica para documentacao da API; se vazio, usa {backend_base}/docs
PUBLIC_API_DOC_URL=

# Email (recuperacao de senha)
# - console: imprime o email no stdout (bom para dev)
# - smtp: envia via SMTP
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Recuperacao de senha
# URL base do frontend (se vazio, usa FRONTEND_ORIGIN + /reset-password)
PASSWORD_RESET_URL=
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# Segredo opcional para hashear tokens (fallback: SECRET_KEY)
PASSWORD_RESET_TOKEN_SECRET=
# Em dev, retorna token/reset_url no JSON do forgot-password
PASSWORD_RESET_DEBUG=false

# Seed (dev)
SEED_PASSWORD=Senha123!

# Cadastro de usuarios:
# - public: cadastro aberto (legado)
# - invite: exige header x-registration-token
# - closed: bloqueia cadastro publico
USER_REGISTRATION_MODE=public
USER_REGISTRATION_INVITE_TOKEN=

# Rate limiting em memoria (janela deslizante)
USER_REGISTRATION_RATE_LIMIT_MAX=30
USER_REGISTRATION_RATE_LIMIT_WINDOW_SEC=60
FORGOT_PASSWORD_RATE_LIMIT_MAX=20
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SEC=60
