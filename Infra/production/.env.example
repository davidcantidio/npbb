# Modo inicial por IP. Para o cutover final, troque para `domain`.
DEPLOY_MODE=ip
ENABLE_TLS=false

# Endpoints publicos da fase de homologacao por IP.
PUBLIC_HOST=187.77.51.117
VITE_API_BASE_URL=http://187.77.51.117/api
FRONTEND_ORIGIN=http://187.77.51.117
PUBLIC_APP_BASE_URL=http://187.77.51.117
PUBLIC_LANDING_BASE_URL=http://187.77.51.117
PUBLIC_API_DOC_URL=http://187.77.51.117/api/docs
PASSWORD_RESET_URL=http://187.77.51.117/reset-password
API_ROOT_PATH=/api

# Dominios finais para o cutover com Cloudflare.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
TLS_CERT_PATH=/etc/nginx/certs/origin.crt
TLS_KEY_PATH=/etc/nginx/certs/origin.key
CERTS_DIR=/opt/npbb/certs

# Postgres local na VPS.
POSTGRES_USER=npbb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=npbb
DATABASE_URL=postgresql+psycopg2://npbb:change-me@postgres:5432/npbb?sslmode=disable
DIRECT_URL=postgresql+psycopg2://npbb:change-me@postgres:5432/npbb?sslmode=disable

# Backend / auth
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false
ENV=production
SQL_ECHO=false

# Recuperacao de senha e email
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=seu-usuario@seudominio.com
SMTP_PASSWORD=change-me
SMTP_FROM=seu-usuario@seudominio.com
SMTP_TLS=true
SMTP_SSL=false
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_SECRET=change-me
PASSWORD_RESET_DEBUG=false

# Cadastro / seed
SEED_PASSWORD=Senha123!
USER_REGISTRATION_MODE=public
USER_REGISTRATION_INVITE_TOKEN=
USER_REGISTRATION_RATE_LIMIT_MAX=30
USER_REGISTRATION_RATE_LIMIT_WINDOW_SEC=60
FORGOT_PASSWORD_RATE_LIMIT_MAX=20
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SEC=60

# Backup local do Postgres
BACKUP_HOST_DIR=/opt/npbb/backups/postgres
BACKUP_FILE_PREFIX=npbb
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"

# Operacao
TZ=America/Sao_Paulo

# Credenciais opcionais para smoke funcional autenticado.
SMOKE_LOGIN_EMAIL=
SMOKE_LOGIN_PASSWORD=
