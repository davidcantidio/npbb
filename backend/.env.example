
# Connect to Supabase via connection pooling (sem query param extra)
DATABASE_URL="postgresql+psycopg2://postgres.jwiznrbfzhidhrpxtvhl:%40liceDioH%26lena123@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"

# Conexão direta (migrations/seed)
DIRECT_URL="postgresql+psycopg2://postgres.jwiznrbfzhidhrpxtvhl:%40liceDioH%26lena123@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

SQL_ECHO=false

# Auth / JWT
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Email / Recuperacao de senha
# - console: imprime email no stdout (padrao em dev)
# - smtp: envia via SMTP (configure SMTP_*)
EMAIL_BACKEND=console

# URL base para o link de reset (o token sera adicionado em ?token=...)
PASSWORD_RESET_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_DEBUG=false
# PASSWORD_RESET_TOKEN_SECRET=change-me (opcional; usa SECRET_KEY se ausente)

# SMTP (apenas se EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false
